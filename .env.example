# ══════════════════════════════════════════════════════════════════════════════
# AnimeDex — Environment Variables
# Copy this file to .env.local for local development.
# In production, set these in your Vercel dashboard (Settings → Environment Variables).
# ══════════════════════════════════════════════════════════════════════════════

# ── AniList OAuth (required for login) ────────────────────────────────────────
#
# Setup:
#   1. Go to https://anilist.co/settings/developer
#   2. Click "+ New Client"
#   3. Set:
#        Name:         AnimeDex
#        Redirect URI: http://localhost:3000/api/auth/callback  ← for local dev
#                      https://yoursite.vercel.app/api/auth/callback  ← for production
#        Type:         Web  ← MUST be "Web" not "Pin"
#   4. Copy the Client ID (number) and Client Secret (long string)
#
# ⚠️  REDIRECT URI MUST MATCH EXACTLY — even a trailing slash difference = "invalid_client"
# ⚠️  Use HTTPS in production, HTTP only for localhost
#
ANILIST_CLIENT_ID=123456
ANILIST_CLIENT_SECRET=your_secret_here
ANILIST_REDIRECT_URI=http://localhost:3000/api/auth/callback
NEXTAUTH_SECRET=change_this_to_a_random_32_char_string

# ── Cloudflare Proxy (required for streaming) ─────────────────────────────────
#
# Deploy cf-proxy/ to Cloudflare Workers:
#   cd cf-proxy && npm install && npm run deploy
# Then set the URL of your deployed worker here:
#
NEXT_PUBLIC_PROXY_URL=https://animedex-proxy.yoursubdomain.workers.dev

# ── Site URL (required for auth redirects and SSR fetches) ────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Crysoline API Key ─────────────────────────────────────────────────────────
CRYSOLINE_API_KEY=your_crysoline_key_here

# ── Upstash Redis (caching — strongly recommended, free tier available) ────────
# Get at https://upstash.com — no credit card required
UPSTASH_REDIS_REST_URL=https://your-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# ── Turso SQLite (source mapping persistence — strongly recommended) ──────────
# Get at https://turso.tech — free tier available
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your_token_here
