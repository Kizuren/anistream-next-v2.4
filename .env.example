# ── REQUIRED ──────────────────────────────────────────────────────────────────
# Crysoline API key (server-side only — never sent to browser)
CRYSOLINE_API_KEY=your_crysoline_key_here

# ── TMDB (embed-only, optional but recommended) ───────────────────────────────
# Get free key: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_key_here

# ── CACHE LAYER 1: Upstash Redis (strongly recommended) ──────────────────────
# Free tier at https://upstash.com — no credit card required
UPSTASH_REDIS_REST_URL=https://your-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# ── CACHE LAYER 2: Turso SQLite (strongly recommended) ───────────────────────
# Free tier at https://turso.tech
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your_token_here

# ── AniList OAuth ─────────────────────────────────────────────────────────────
# 1. Go to https://anilist.co/settings/developer
# 2. Create a new API client
# 3. Set the Redirect URI to:  http://localhost:3000/auth/callback
#    (use your production domain in prod)
#
# NEXT_PUBLIC_ prefix = exposed to browser (needed for the login redirect URL)
# The plain variable = server-only (used for token exchange)
#
NEXT_PUBLIC_ANILIST_CLIENT_ID=18795
ANILIST_CLIENT_ID=18795          # same value, server-side alias
ANILIST_CLIENT_SECRET=bttAT8kLGPs1v9mNn9OHLFPwHdf0TLJgF1SwCOhD  # KEEP SECRET — never NEXT_PUBLIC_
ANILIST_REDIRECT_URI=http://localhost:3000/auth/callback
